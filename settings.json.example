{
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/absolute/path/to/hooks/jj-worktree-create.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/absolute/path/to/hooks/jj-worktree-remove.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}